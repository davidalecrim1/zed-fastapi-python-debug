[
  {
    "label": "Python Debugger: Pytest",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "pytest",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "python": "${ZED_WORKTREE_ROOT}/.venv/bin/python",
    "justMyCode": true,
    "env": {
      "MY_VARIABLE": "abcd",
    },
  },
  {
    "label": "Python Debugger: FastAPI",
    "adapter": "Debugpy",
    "request": "launch",
    "module": "uvicorn",
    "cwd": "${ZED_WORKTREE_ROOT}",
    "args": ["main:app", "--reload", "--port", "3000"],
    "jinja": true,
    "justMyCode": true,
    "autoReload": {
      "enable": true,
    },
    "env": {
      "MY_VARIABLE": "abcd",
    },
  },
]
